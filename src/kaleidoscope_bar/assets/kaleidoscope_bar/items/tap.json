{
    "model": {
        "type": "select",
        "property": "display_context",
        "cases": [
            {
                "when": ["firstperson_lefthand","firstperson_righthand","fixed","ground","gui","head","thirdperson_lefthand","thirdperson_righthand"],
                "model": {
                    "type": "model",
                    "model": "kaleidoscope_bar:item/tap/item"
                }
            }
        ],
        "fallback": {
            "type": "condition",
            "property": "custom_model_data",
            "index": 0,
            "on_false": {
                "type": "model",
                "model": "kaleidoscope_bar:item/tap/close"
            },
            "on_true": {
                "type": "model",
                "model": "kaleidoscope_bar:item/tap/open"
            }
        }
    }
}