# 【melon_platter】西瓜拼盘
data modify storage dc:index input.melon_platter set value { \
    modsize:[1f,1f,1f], \
    interactsize:{height:0.3f,width:1f}, \
    loot_table:"kaleidoscope_meals:melon_platter", \
    item:{ \
        components:{ \
            "minecraft:item_model":"kaleidoscope_cookery:meals/melon_platter", \
            "minecraft:custom_model_data":{floats:[0]} \
        }, \
    }, \
    template:"kaleidoscope", \
    events:{ \
        "construct":[ \
            {event:"sound",args:{sound:"minecraft:block.wood.place"}}, \
        ], \
        left_click:{ \
            fallback:{event:"destruct",args:{item:{},particle:"block{block_state:\"oak_planks\"}",sound:"minecraft:block.wood.break"}} \
        }, \
        right_click:{ \
                "fallback": {\
                    "event": "trans",\
                    "args": {\
                        "index": "melon_platter_1",\
                        "func": "kaleidoscope_meals:effect/eat/melon_platter"\
                    }\
                }\
            } \
    } \
} 
data modify storage dc:index keylist append value "melon_platter" 

